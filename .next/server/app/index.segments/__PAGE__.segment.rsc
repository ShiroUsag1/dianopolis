 agropecuária, comércio e serviços, mantendo relevância regional. Hoje, também se destaca pelo turismo, com belezas naturais e patrimônio cultural, enquanto preserva suas raízes e busca desenvolvimento e um futuro próspero."]}]}]]}],["$","div",null,{"className":"row","children":["$","div",null,{"className":"col","children":["$","$L2",null,{"className":"page-module___8aEwW__deputado","src":"/CIDADE 3.jpg","alt":"Foto da entrada da cidade","width":350,"height":500}]}]}]]}]}],"$L3","$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10"]}],["$L11","$L12","$L13"],"$L14"]}],"loading":null,"isPartial":false}
